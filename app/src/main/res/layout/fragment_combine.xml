<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/page_top_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/page_bottom_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/combine_page_header"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/combineInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/combine_selection_instructions"/>

        <Button
            android:id="@+id/combineOpenSelectorButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/combine_selector_open"/>

        <ListView
            android:id="@+id/virusList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/page_spacing_large"
            android:layout_weight="1"
            android:choiceMode="multipleChoice"
            android:overScrollMode="ifContentScrolls"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_large"
            android:text="@string/combine_latest_label"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/resultSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/combine_result_info_none"/>

        <Button
            android:id="@+id/combineButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_large"
            android:text="@string/combine_local_button"/>

        <Button
            android:id="@+id/combine_back_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/virus_back_to_lab_button"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/combineSelectorPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="@dimen/page_spacing_large"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/combine_selector_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/combineSelectorSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/combine_selector_none_selected" />

        <ListView
            android:id="@+id/combineSelectorList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/page_spacing_medium"
            android:layout_weight="1"
            android:choiceMode="none"
            android:overScrollMode="ifContentScrolls" />

        <Button
            android:id="@+id/combineCloseSelectorButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/combine_selector_done" />
    </LinearLayout>

</FrameLayout>

