<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/combineDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main collection content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/page_top_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/page_bottom_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/collection_name_label"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/userNameInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:autofillHints="name,username"
                android:hint="@string/collection_name_hint"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:minHeight="48dp"/>

            <Button
                android:id="@+id/saveUserNameButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/page_spacing_small"
                android:minHeight="48dp"
                android:text="@string/collection_name_save_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/collectionSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_medium"
            android:text="@string/collection_virus_list_label"
            android:textSize="16sp" />

        <ListView
            android:id="@+id/virusList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:layout_weight="1"
            android:choiceMode="none"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/page_spacing_small"
            android:overScrollMode="ifContentScrolls" />

        <Button
            android:id="@+id/createVirusButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:minHeight="48dp"
            android:text="@string/create_virus_button" />

    </LinearLayout>

    <!-- Combine selector panel – right-side drawer -->
    <LinearLayout
        android:id="@+id/combineSelectorPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="@dimen/page_spacing_large">

        <!-- Panel title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/combine_page_header"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Pinned (left) virus – always included, disabled -->
        <LinearLayout
            android:id="@+id/pinnedVirusRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_medium"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/pinnedVirusName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pinnedVirusMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Greyed-out, non-interactive checkbox -->
            <CheckBox
                android:id="@+id/pinnedVirusCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:clickable="false"
                android:enabled="false"
                android:focusable="false" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:background="@android:color/darker_gray" />

        <!-- Partner selection summary -->
        <TextView
            android:id="@+id/combineSelectorSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:text="@string/combine_selector_none_selected" />

        <!-- Partner virus list -->
        <ListView
            android:id="@+id/combineSelectorList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:layout_weight="1"
            android:choiceMode="none"
            android:overScrollMode="ifContentScrolls" />

        <!-- Action button – immediately combines and opens the new virus -->
        <Button
            android:id="@+id/combineActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_medium"
            android:text="@string/combine_action_button" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
