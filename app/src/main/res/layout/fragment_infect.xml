<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
                                       android:layout_width="match_parent"
                                       android:layout_height="match_parent"
                                       android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/infect_view_title"
                android:textSize="24sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/infect_view_instructions"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/infect_view_list_label"
                android:textStyle="bold"/>

        <ListView
                android:id="@+id/virusList"
                android:layout_width="match_parent"
                android:layout_height="@dimen/virus_list_height"
                android:layout_marginTop="6dp"
                android:choiceMode="multipleChoice"
                android:nestedScrollingEnabled="true"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/infect_view_invite_label"
                android:textStyle="bold"/>

        <EditText
                android:id="@+id/friendCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:autofillHints=""
                android:importantForAutofill="no"
                android:gravity="top|start"
                android:hint="@string/infect_view_invite_instructions"
                android:inputType="textMultiLine"
                android:maxLines="6"
                android:minLines="3"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical"
                android:scrollHorizontally="false"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/infectButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/infect_view_infect_button"/>

            <Button
                    android:id="@+id/shareButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/infect_view_show_qr_button"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/shareTextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/infect_view_share_text_button"/>

            <Button
                    android:id="@+id/scanQrButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/infect_view_scan_qr_button"/>
        </LinearLayout>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/infect_view_latest_outbreak_label"
                android:textSize="18sp"
                android:textStyle="bold"/>

        <TextView
                android:id="@+id/resultSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/infect_view_latest_outbreak_missing_text"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

