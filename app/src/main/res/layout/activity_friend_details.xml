<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_horizontal_padding">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_medium"
            android:layout_marginBottom="@dimen/page_spacing_medium"
            app:cardCornerRadius="@dimen/surface_card_corner_radius"
            app:cardElevation="@dimen/surface_card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_spacing_large">

                <TextView
                    android:id="@+id/friendDetailsName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/friendDetailsLastInfection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/friendDetailsDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_medium"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_large"
                    android:text="@string/friend_notes_label"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/friendDetailsNotesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/friendDetailsNotesActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/friendDetailsEditNotesButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/friend_notes_edit" />

                    <Button
                        android:id="@+id/friendDetailsClearNotesButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/page_spacing_small"
                        android:text="@string/friend_notes_clear" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/friendDetailsNotesEditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/friendDetailsNotesInput"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="top|start"
                        android:hint="@string/friend_notes_hint"
                        android:inputType="textMultiLine"
                        android:maxLines="6" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/page_spacing_small"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/friendDetailsCancelNotesButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/friend_notes_cancel" />

                        <Button
                            android:id="@+id/friendDetailsSaveNotesButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/page_spacing_small"
                            android:text="@string/friend_notes_save" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/friendDetailsToggleHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_large"
                    android:text="@string/friend_history_show" />

                <ScrollView
                    android:id="@+id/friendDetailsHistoryContainer"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/friendDetailsHistoryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp" />
                </ScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_large"
                    android:text="@string/friend_associated_viruses_label"
                    android:textStyle="bold" />

                <ListView
                    android:id="@+id/friendDetailsVirusList"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="@dimen/page_spacing_small"
                    android:dividerHeight="@dimen/page_spacing_small" />

                <Button
                    android:id="@+id/friendDetailsBackButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/page_spacing_large"
                    android:text="@string/virus_back_to_lab_button" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

