<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="@dimen/page_horizontal_padding"
    android:paddingTop="@dimen/page_top_padding"
    android:paddingEnd="@dimen/page_horizontal_padding"
    android:paddingBottom="@dimen/page_bottom_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/create_page_header"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/page_spacing_large"
        android:text="@string/lab_seed_title"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/labSeedInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/page_spacing_small"
        android:hint="@string/lab_seed_hint"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/create_latest_creation_label"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/resultSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/page_spacing_small"
        android:text="@string/create_latest_creation_info_none"/>

    <Button
        android:id="@+id/createButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/page_spacing_large"
        android:text="@string/create_virus_button"/>

</LinearLayout>

