<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/page_top_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/page_bottom_padding">

        <!-- Username section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_username_label"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/settingsUserNameInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:autofillHints="name,username"
                android:hint="@string/settings_username_hint"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:minHeight="48dp" />

            <Button
                android:id="@+id/settingsSaveUserNameButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/page_spacing_small"
                android:minHeight="48dp"
                android:text="@string/settings_username_save_button" />
        </LinearLayout>

        <!-- Night mode section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_large"
            android:text="@string/settings_night_mode_label"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/settingsNightModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_small"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/settingsNightModeSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/settings_night_mode_system" />

            <RadioButton
                android:id="@+id/settingsNightModeLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/settings_night_mode_light" />

            <RadioButton
                android:id="@+id/settingsNightModeNight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/settings_night_mode_night" />

        </RadioGroup>

        <CheckBox
            android:id="@+id/settingsShowSelfInFriendsCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_spacing_large"
            android:minHeight="48dp"
            android:text="@string/settings_show_self_in_friends" />

    </LinearLayout>
</ScrollView>
